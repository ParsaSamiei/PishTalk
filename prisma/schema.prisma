// Prisma schema for Pishtalk.
// Structure follows docs/05_DATABASE.md. Do not rename fields or models
// without updating that document first.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
  EDITOR
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  CANCELLED
}

enum RegistrationStatus {
  REGISTERED
  CANCELLED
  ATTENDED
}

enum ResourceType {
  PDF
  PRESENTATION
  GITHUB
  VIDEO
  RESEARCH_PAPER
  EXTERNAL_LINK
}

enum GalleryMediaType {
  IMAGE
  VIDEO
}

model Admin {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         AdminRole @default(ADMIN)
  avatar       String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@map("admins")
}

model Event {
  id          String      @id @default(uuid())
  slug        String      @unique
  title       String
  subtitle    String?
  description String
  coverImage  String?     @map("cover_image")
  date        DateTime    @db.Date
  startTime   String      @map("start_time")
  endTime     String?     @map("end_time")
  location    String
  speakerName String?     @map("speaker_name")
  speakerBio  String?     @map("speaker_bio")
  capacity    Int?
  status      EventStatus @default(DRAFT)

  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description")
  ogImage        String? @map("og_image")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  timeline      EventTimelineItem[]
  registrations Registration[]
  resources     Resource[]
  gallery       Gallery?

  @@index([slug])
  @@index([date])
  @@index([status])
  @@map("events")
}

model EventTimelineItem {
  id          String @id @default(uuid())
  eventId     String @map("event_id")
  time        String
  title       String
  description String?
  sortOrder   Int    @default(0) @map("sort_order")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_timelines")
}

model Registration {
  id         String             @id @default(uuid())
  eventId    String             @map("event_id")
  firstName  String             @map("first_name")
  lastName   String             @map("last_name")
  phone      String
  email      String?
  university String?
  company    String?
  profession String?
  notes      String?
  status     RegistrationStatus @default(REGISTERED)
  createdAt  DateTime           @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([phone])
  @@index([email])
  @@map("registrations")
}

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?

  blogs Blog[]

  @@map("categories")
}

model Blog {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?   @map("cover_image")
  categoryId  String?   @map("category_id")
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  readingTime Int?      @map("reading_time")

  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  category Category? @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([published])
  @@index([categoryId])
  @@index([createdAt])
  @@map("blogs")
}

model Gallery {
  id          String   @id @default(uuid())
  eventId     String   @unique @map("event_id")
  title       String
  description String?
  coverImage  String?  @map("cover_image")
  createdAt   DateTime @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  event Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  media GalleryMedia[]

  @@map("galleries")
}

model GalleryMedia {
  id        String           @id @default(uuid())
  galleryId String           @map("gallery_id")
  type      GalleryMediaType @default(IMAGE)
  url       String
  thumbnail String?
  caption   String?
  sortOrder Int              @default(0) @map("sort_order")

  gallery Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@map("gallery_media")
}

model Resource {
  id           String       @id @default(uuid())
  eventId      String?      @map("event_id")
  title        String
  description  String?
  resourceType ResourceType @map("resource_type")
  fileUrl      String?      @map("file_url")
  externalUrl  String?      @map("external_url")
  createdAt    DateTime     @default(now()) @map("created_at")
  deletedAt    DateTime?    @map("deleted_at")

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@map("resources")
}

model Faq {
  id        String  @id @default(uuid())
  question  String
  answer    String
  sortOrder Int     @default(0) @map("sort_order")
  published Boolean @default(true)

  @@map("faqs")
}

model Rule {
  id          String  @id @default(uuid())
  title       String
  description String
  icon        String?
  sortOrder   Int     @default(0) @map("sort_order")
  published   Boolean @default(true)

  @@map("rules")
}

/// Not listed in docs/05_DATABASE.md's table overview, but the Contact Form
/// component (docs/04_DESIGN_SYSTEM.md) needs somewhere to land submissions
/// until an email provider is wired up. Minimal by design.
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

/// Singleton table: exactly one row should ever exist.
model SiteSettings {
  id               String  @id @default(uuid())
  siteName         String  @default("پیشتاک") @map("site_name")
  tagline          String  @default("جامعه مهندسان رباتیک، هوش مصنوعی و فناوری")
  description      String?
  logo             String?
  favicon          String?
  heroTitle        String? @map("hero_title")
  heroSubtitle     String? @map("hero_subtitle")
  contactEmail     String? @map("contact_email")
  phone            String?
  address          String?
  instagram        String?
  telegram         String?
  pishnamUrl       String? @map("pishnam_url")
  googleMapsEmbed  String? @map("google_maps_embed")
  copyright        String?
  seoTitle         String? @map("seo_title")
  seoDescription   String? @map("seo_description")
  defaultOgImage   String? @map("default_og_image")
  /// Not in docs/05_DATABASE.md's field list, but docs/07_ADMIN_PANEL.md's
  /// Site Settings screen explicitly has an "Analytics: Google Analytics"
  /// field. Added as a minimal, optional extension.
  googleAnalyticsId String? @map("google_analytics_id")
  maintenanceMode  Boolean @default(false) @map("maintenance_mode")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
